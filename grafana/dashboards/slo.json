{
  "id": null,
  "uid": "slo-dashboard",
  "title": "SLO / Error Budget Dashboard",
  "tags": [
    "ecommerce",
    "agent",
    "slo",
    "error-budget"
  ],
  "timezone": "utc",
  "schemaVersion": 36,
  "refresh": "30s",
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "name": "SLO Breaches",
        "datasource": {
          "type": "prometheus",
          "uid": "mimir"
        },
        "expr": "slo:availability:ratio_30d \u003c 99.9 or slo:latency:p95_7d \u003e 2 or slo:accuracy:intent_7d \u003c 0.98",
        "iconColor": "red",
        "tags": ["slo", "breach"],
        "type": "tags"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Availability SLO — Current vs Target",
      "type": "gauge",
      "targets": [
        {
          "expr": "slo:availability:ratio_30d",
          "legendFormat": "Availability %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 99,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99.9 },
              { "color": "green", "value": 99.95 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Availability — Error Budget Remaining",
      "type": "stat",
      "targets": [
        {
          "expr": "((slo:availability:ratio_30d - 99.9) / 0.1) * 100",
          "legendFormat": "Budget %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "title": "Availability — Burn Rate",
      "type": "graph",
      "targets": [
        {
          "expr": "slo:availability:error_rate_30d / 0.1",
          "legendFormat": "Burn Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 14.4 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "title": "Availability — 30-Day Trend",
      "type": "graph",
      "targets": [
        {
          "expr": "slo:availability:ratio_30d",
          "legendFormat": "Availability %"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
    },
