    {
      "id": 23,
      "title": "Burn Rate — All SLOs",
      "type": "graph",
      "targets": [
        {
          "expr": "slo:availability:error_rate_30d / 0.1",
          "legendFormat": "Availability Burn"
        },
        {
          "expr": "clamp_min(slo:latency:p95_7d / 2, 0)",
          "legendFormat": "Latency Burn"
        },
        {
          "expr": "clamp_min((0.98 - slo:accuracy:intent_7d) / 0.02, 0)",
          "legendFormat": "Accuracy Burn"
        },
        {
          "expr": "clamp_min(((slo:cost:token_per_request_30d * 0.00001) - 0.05) / 0.05, 0)",
