        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 10,
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
