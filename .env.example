# Project
PROJECT_NAME=E-commerce Smart Agent
API_V1_STR=/api/v1

# Database
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=knowledge_base

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Redis (应用必填) - 本地开发时 docker-compose 默认使用 devpassword
REDIS_PASSWORD=devpassword

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# LLM
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
DASHSCOPE_API_KEY=your-dashscope-api-key

# Reranker
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1

# LangSmith / LangChain tracing
LANGCHAIN_TRACING_V2=False
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ecommerce-smart-agent
LANGSMITH_OTEL_ENABLED=False

# LLM 模型配置（可选，不填时使用默认值）
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAPI docs (set to False in production)
ENABLE_OPENAPI_DOCS=True

# CORS (JSON array format required by Pydantic Settings v2)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Celery
CELERY_BROKER_URL=redis://:devpassword@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:devpassword@localhost:6379/0
